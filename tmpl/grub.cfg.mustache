##### Arch and Manjaro #####
# Note: These both use multiple initrd images. Unlike pxelinux, they need to be **space delimited** (not comma, ',')

### Arch
# GRUB (only) error at start/top of screen): Initramfs unpacking failed: invalid magic at start of compressed archive
# ... Kernel panic - not syncing: VFS: Unable to mount root fs on unknown-block(1,0)
menuentry "Arch Linux (Live Console, No Auto Install)" {
  # BOOTIF=01-${net_default_mac} or rd.bootif=0
  linux /archlinux/arch/boot/x86_64/vmlinuz-linux archisobasedir=arch archiso_http_srv=http://{{ httpserver }}/archlinux/ BOOTIF=01-${net_default_mac} ip=dhcp
  # Grub support for multiple initrd items: Do not include http server part here.
  initrd /archlinux/arch/boot/intel-ucode.img /archlinux/arch/boot/amd-ucode.img /archlinux/arch/boot/x86_64/initramfs-linux.img
}
### Manjaro
# Initial Errors ... Please append a correct "root=" boot option. Solved by stripping out 'http://{{httpserver}}' part (GRUB has global sever config)
menuentry "Manjaro XFCE (Live NFS or HTTP)" {
  # Suggested (for linux ...): misobasedir=manjaro misolabel=MANJARO_XFCE miso_nfs_srv=${server_ip}:${nfs_path} ip=dhcp
  #    nouveau.modeset=1 i915.modeset=1 radeon.modeset=1
  # Also: miso_http_srv=... Also: misolabel=MANJARO_XFCE ??? BOOTIF=01-${net_default_mac} or rd.bootif=0
  linux /manjaro/boot/vmlinuz-x86_64 miso_http_srv=http://{{ httpserver }}/manjaro/ ip=dhcp misobasedir=manjaro misolabel=manjaro
  # Must have 3 nfs:// items (as of 2021 forum). Order matters: Microcode must come BEFORE the main initramfs
  initrd /manjaro/boot/amd_ucode.img /manjaro/boot/intel_ucode.img /manjaro/boot/initramfs-x86_64.img
}
